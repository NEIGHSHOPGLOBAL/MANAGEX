[Unit]
Description=ManageX Flask Backend
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/opt/managex/backend
Environment=TZ=Asia/Kolkata
EnvironmentFile=/opt/managex/backend/.env
ExecStart=/opt/managex/backend/venv/bin/gunicorn -w 3 -b 127.0.0.1:5033 --timeout 120 wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
